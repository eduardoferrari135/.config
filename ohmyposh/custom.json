{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "palette": {
    "base":      "#1e1e2e",
    "mantle":    "#181825",
    "surface0":  "#313244",
    "surface1":  "#45475a",
    "surface2":  "#585b70",
    "overlay0":  "#6c7086",
    "overlay1":  "#7f849c",
    "overlay2":  "#9399b2",
    "subtext0":  "#a6adc8",
    "subtext1":  "#bac2de",
    "text":      "#cdd6f4",
    "lavender":  "#b4befe",
    "blue":      "#89b4fa",
    "sapphire":  "#74c7ec",
    "sky":       "#89dceb",
    "teal":      "#94e2d5",
    "green":     "#a6e3a1",
    "yellow":    "#f9e2af",
    "peach":     "#fab387",
    "maroon":    "#eba0ac",
    "red":       "#f38ba8",
    "mauve":     "#cba6f7",
    "pink":      "#f5c2e7",
    "flamingo":  "#f2cdcd",
    "rosewater": "#f5e0dc"
  },
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "type": "path",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "background": "p:blue",
          "foreground": "p:base",
          "properties": {
            "style": "full",
            "folder_separator_icon": " \ue0b1 ",
            "home_icon": "~"
          },
          "template": "  {{ .Path }} "
        },
        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "background": "p:green",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}p:yellow{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}p:peach{{ end }}",
            "{{ if gt .Ahead 0 }}p:sky{{ end }}",
            "{{ if gt .Behind 0 }}p:maroon{{ end }}"
          ],
          "foreground": "p:base",
          "properties": {
            "branch_icon": "\ue725 ",
            "fetch_status": true,
            "fetch_upstream_icon": true,
            "commit_icon": "\uf417 ",
            "tag_icon": "\uf412 ",
            "cherry_pick_icon": "\ue29b ",
            "rebase_icon": "\ue728 ",
            "merge_icon": "\ue727 ",
            "no_commits_icon": "\uf0c3 ",
            "revert_icon": "\uf0e2 "
          },
          "template": " {{ .HEAD }}{{ if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} \uf01c {{ .StashCount }}{{ end }} "
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "segments": [
        {
          "type": "python",
          "style": "diamond",
          "leading_diamond": "\ue0b2",
          "trailing_diamond": "",
          "background": "p:yellow",
          "foreground": "p:base",
          "properties": {
            "display_mode": "files",
            "fetch_virtual_env": true,
            "cache_duration": "none"
          },
          "template": " \ue235 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}{{ if .Venv }} ({{ .Venv }}){{ end }} "
        },
        {
          "type": "go",
          "style": "diamond",
          "leading_diamond": "\ue0b2",
          "trailing_diamond": "",
          "background": "p:sky",
          "foreground": "p:base",
          "properties": {
            "display_mode": "files",
            "cache_duration": "none"
          },
          "template": " \ue626 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} "
        },
        {
          "type": "rust",
          "style": "diamond",
          "leading_diamond": "\ue0b2",
          "trailing_diamond": "",
          "background": "p:peach",
          "foreground": "p:base",
          "properties": {
            "display_mode": "files",
            "cache_duration": "none"
          },
          "template": " \ue7a8 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} "
        },
        {
          "type": "swift",
          "style": "diamond",
          "leading_diamond": "\ue0b2",
          "trailing_diamond": "",
          "background": "p:rosewater",
          "foreground": "p:base",
          "properties": {
            "display_mode": "files",
            "cache_duration": "none"
          },
          "template": " \ue755 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} "
        },
        {
          "type": "time",
          "style": "diamond",
          "leading_diamond": "\ue0b2",
          "trailing_diamond": "",
          "background": "p:surface1",
          "foreground": "p:subtext1",
          "properties": {
            "time_format": "15:04:05"
          },
          "template": "  {{ .CurrentDate | date .Format }} "
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground": "p:mauve",
          "foreground_templates": [
            "{{ if gt .Code 0 }}p:red{{ end }}"
          ],
          "template": "❯ "
        }
      ],
      "type": "prompt"
    }
  ],
  "final_space": true,
  "version": 3
}
